{
  "name": "moorthyptm-portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Thirumoorthy Ponnusamy — portfolio site",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @moorthyptm/portfolio dev",
    "build": "pnpm --filter @moorthyptm/portfolio build",
    "format": "prettier --check \"**/*.{ts,js,json,md,yml,yaml,html,css}\"",
    "format:fix": "prettier --write \"**/*.{ts,js,json,md,yml,yaml,html,css}\""
  },
  "devDependencies": {
    "prettier": "^3.6.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  }
}
