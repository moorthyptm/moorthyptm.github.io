node-linker=hoisted
auto-install-peers=true
strict-peer-dependencies=false

# Supply-chain delay: refuse to install packages whose newest published
# version is younger than 7 days (10080 minutes). Buys time for the
# community to surface a freshly compromised release before it reaches our
# lockfile. pnpm 10+ feature; honoured by `pnpm install` and `pnpm update`.
# Override per-install with --ignore-pnpmfile if a security patch needs
# faster pickup.
minimum-release-age=10080
